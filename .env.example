# Emotional Intelligence AI Configuration
# Copy this file to .env and fill in the values

# OpenAI API key for LLM-powered rewriting
OPENAI_API_KEY=sk-your-openai-api-key

# Model selection (gpt-4, gpt-3.5-turbo)
OPENAI_MODEL=gpt-4

# Aggression score threshold for auto-rewrite (0-100)
AGGRESSION_THRESHOLD=60

# Default tone for rewrites (neutral, warm, firm)
DEFAULT_TONE=neutral

# Enable child-focus filter by default
CHILD_FOCUS_ENABLED=true

# Court readiness minimum score (0-100)
COURT_READINESS_MINIMUM=70

# Logging level (debug, info, warn, error)
LOG_LEVEL=info

# Maximum message length (characters)
MAX_MESSAGE_LENGTH=5000
